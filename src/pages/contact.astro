---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">
  <h1>Contact</h1>

  <div class="contact-sections">
    <section class="contact-section">
      <h2>Professional</h2>

      <ul class="contact-list">
        <li>
          <a class="contact-link" href="mailto:volodymyreznichenko@gmail.com">
            <span class="contact-name">Email</span>
            <span class="contact-meta">Primary contact</span>
          </a>
        </li>

        <li>
          <a
            class="contact-link"
            href="https://www.linkedin.com/in/volodymyr-reznichenko/"
            target="_blank"
            rel="noopener"
          >
            <span class="contact-name">LinkedIn</span>
            <span class="contact-meta">Professional network</span>
          </a>
        </li>

        <li>
          <a
            class="contact-link"
            href="https://github.com/vreznichenko"
            target="_blank"
            rel="noopener"
          >
            <span class="contact-name">GitHub</span>
            <span class="contact-meta">Code & projects</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="contact-section">
      <h2>Personal</h2>

      <ul class="contact-list">
        <li>
          <a
            class="contact-link"
            href="https://x.com/VolodRez"
            target="_blank"
            rel="noopener"
          >
            <span class="contact-name">X</span>
            <span class="contact-meta">Short thoughts</span>
          </a>
        </li>


        <li>
          <a
            class="contact-link"
            href="https://www.instagram.com/palefacedzp/"
            target="_blank"
            rel="noopener"
          >
            <span class="contact-name">Instagram</span>
            <span class="contact-meta">Life moments</span>
          </a>
        </li>


        <li>
          <a
            class="contact-link"
            href="https://www.youtube.com/@volodreznichenko5547"
            target="_blank"
            rel="noopener"
          >
            <span class="contact-name">YouTube</span>
            <span class="contact-meta">Videos</span>
          </a>
        </li>



      </ul>
    </section>
  </div>
</BaseLayout>