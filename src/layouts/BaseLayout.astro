---
const { title = "Volod" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

<style>
  :root {
    --max: 760px;
    --pad: 22px;

    --font: ui-serif, Georgia, "Times New Roman", serif;
    --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;

    --r: 12px;

    /* default = “System” (we let prefers-color-scheme decide) */
    --bg: #ffffff;
    --text: #111111;
    --muted: #555555;
    --rule: #e9e9e9;

    --accent: #0f766e; /* forest default */
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0b0c0f;
      --text: #eaeaea;
      --muted: #b9b9b9;
      --rule: #1f2430;
    }
/* derived accent surfaces (works in modern browsers) */
:root {
  --accent-soft: color-mix(in srgb, var(--accent) 7%, var(--bg));
  --accent-surface: color-mix(in srgb, var(--accent) 12%, var(--bg));
  --accent-ink: color-mix(in srgb, var(--accent) 75%, var(--text));
}

  }

  /* Mode overrides (when user explicitly chooses) */
  html[data-mode="light"] {
    --bg: #ffffff;
    --text: #111111;
    --muted: #555555;
    --rule: #e9e9e9;
  }

  html[data-mode="dark"] {
    --bg: #0b0c0f;
    --text: #eaeaea;
    --muted: #b9b9b9;
    --rule: #1f2430;
  }

  /* Accent overrides */
  html[data-accent="forest"] { --accent: #0f766e; }
  html[data-accent="coral"]  { --accent: #e76f51; }
  html[data-accent="ocean"]  { --accent: #2563eb; }
  html[data-accent="ember"]  { --accent: #b45309; }

  * { box-sizing: border-box; }

body {
  margin: 0;
  background:
    radial-gradient(900px 500px at 85% -10%, var(--accent-soft), transparent 60%),
    var(--bg);
  color: var(--text);
  font-family: var(--font);
  line-height: 1.7;
  font-size: 18px;
  text-rendering: optimizeLegibility;
}


  .wrap {
    max-width: var(--max);
    margin: 56px auto;
    padding: 0 var(--pad);
  }

  .topbar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .toggles {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    align-items: center;
    color: var(--muted);
    font-size: 14px;
  }

  .toggle-group {
    display: inline-flex;
    gap: 6px;
    align-items: center;
    padding: 6px;
    border: 1px solid var(--rule);
    border-radius: var(--r);
  }

  .toggle-group .label {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    margin-right: 6px;
  }

  button.tbtn {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--muted);
    padding: 6px 10px;
    border-radius: 10px;
    cursor: pointer;
    font-family: var(--mono);
    font-size: 12px;
  }

button.tbtn[aria-pressed="true"] {
  color: var(--accent-ink);
  background: var(--accent-surface);
  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 35%, var(--rule));
}


  button.tbtn:hover {
    color: var(--text);
    box-shadow: inset 0 0 0 1px var(--rule);
  }

blockquote {
  margin: 18px 0;
  padding: 14px 16px;
  background: var(--accent-soft);
  border: 1px solid var(--rule);
  border-left: 4px solid var(--accent);
  border-radius: var(--r);
  color: var(--muted);
}


  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    align-items: baseline;
    padding-bottom: 18px;
    margin-bottom: 34px;
    border-bottom: 1px solid var(--rule);
  }

  nav a {
    text-decoration: none;
    color: var(--muted);
    padding: 2px 0;
  }

  nav a:hover {
  color: var(--accent);
  text-decoration-thickness: 2px;
}


  a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  a:hover { text-decoration-thickness: 2px; }

  h1 {
    font-size: 36px;
    line-height: 1.15;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
  }

h2 {
  font-size: 22px;
  margin: 34px 0 10px;
  letter-spacing: -0.01em;
  border-left: 3px solid var(--accent-ink);
  padding-left: 10px;
}


  p { margin: 0 0 14px; }

hr {
  border: 0;
  border-top: 1px solid var(--rule);
  margin: 28px 0;
  position: relative;
}

hr::after {
  content: "";
  display: block;
  width: 60px;
  height: 2px;
  background: var(--accent);
  margin-top: -1px;
}


  ul { margin: 0 0 14px 1.2em; padding: 0; }
  li { margin: 0 0 8px; }

  @media (max-width: 520px) {
    .wrap { margin: 34px auto; }
    body { font-size: 17px; }
    h1 { font-size: 32px; }
  }

nav a.active {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 4px;
}
/* Home hero layout */
.home-hero {
  display: flex;
  gap: 32px;
  align-items: flex-start;
}

.home-link {
  text-decoration: none;
  color: var(--text);
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.02em;
}

.home-link:hover {
  color: var(--accent-ink);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.site-wordmark {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: var(--text-primary);
  text-decoration: none;
  line-height: 1;
}

.site-wordmark:hover {
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 4px;
  text-decoration-color: var(--accent);
}

:global(.home-hero) {
  display: flex;
  gap: 32px;
  align-items: flex-start;
}

:global(.home-hero > div) {
  max-width: 520px;
}

@media (max-width: 640px) {
  :global(.home-hero) {
    flex-direction: column;
    gap: 20px;
  }
}

/* Contact page styling */
:global(.contact-sections) {
  margin-top: 22px;
  display: grid;
  gap: 36px;
}

:global(.contact-section) {
  padding-top: 10px;
}

:global(.contact-section h2) {
  margin-top: 0;
}

:global(.contact-list) {
  list-style: none;
  padding: 0;
  margin: 14px 0 0;
  border-top: 1px solid var(--rule);
}

:global(.contact-list li) {
  border-bottom: 1px solid var(--rule);
}

:global(.contact-link) {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 16px;
  padding: 14px 0;
  text-decoration: none;
  color: var(--text);
}

:global(.contact-name) {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

:global(.contact-meta) {
  color: var(--text);
}

/* “Hide links” feel: no underline, subtle until hover */
:global(.contact-link:hover) {
  background: var(--accent-soft);
}

:global(.contact-link:hover .contact-name) {
  color: var(--accent-ink);
}

:global(.contact-link:hover .contact-meta) {
  color: var(--accent-ink);
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* Mobile */
@media (max-width: 520px) {
  :global(.contact-link) {
    grid-template-columns: 1fr;
    gap: 6px;
    padding: 14px 0;
  }
}

/* Section heading accent rule (Contact + others if reused) */
:global(.contact-section h2) {
  position: relative;
  padding-bottom: 10px;
  margin-bottom: 18px;
}

:global(.contact-section h2::after) {
  content: "";
  display: block;
  width: 48px;
  height: 2px;
  background: var(--accent);
  margin-top: 8px;
}
/* Dropdown nav (About) */
.nav-dd {
  position: relative;
  display: inline-block;
}

.nav-dd-btn {
  appearance: none;
  border: 0;
  background: transparent;
  color: var(--muted);
  padding: 2px 0;
  font: inherit;
  cursor: pointer;
}

.nav-dd-btn:hover {
  color: var(--text);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.nav-dd-btn.active {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 4px;
}

.nav-dd-caret {
  margin-left: 6px;
  font-size: 12px;
  color: currentColor;
}

.nav-dd-menu {
  position: absolute;
  top: calc(100% + 10px);
  left: 0;
  min-width: 180px;
  padding: 8px;
  background: var(--bg);
  border: 1px solid var(--rule);
  border-radius: 12px;
  box-shadow: 0 18px 40px rgba(0,0,0,.10);
  display: none;
  z-index: 10;
}

.nav-dd-menu a {
  display: block;
  padding: 8px 10px;
  border-radius: 10px;
  text-decoration: none;
  color: var(--text);
}

.nav-dd-menu a:hover {
  background: var(--accent-soft);
  color: var(--accent-ink);
}

/* Open on hover (desktop) */
.nav-dd:hover .nav-dd-menu {
  display: block;
}

/* Open on keyboard focus too */
.nav-dd:focus-within .nav-dd-menu {
  display: block;
}

</style>


  </head>
  <body>
  <div class="wrap">
    <div class="topbar">
 

  <div class="toggles" aria-label="Theme controls">
    <div class="toggle-group" role="group" aria-label="Mode">
      <span class="label">Mode</span>
      <button class="tbtn" data-mode-btn="light" type="button" aria-pressed="false">Light</button>
      <button class="tbtn" data-mode-btn="dark" type="button" aria-pressed="false">Dark</button>
      <button class="tbtn" data-mode-btn="system" type="button" aria-pressed="false">System</button>
    </div>

    <div class="toggle-group" role="group" aria-label="Accent">
      <span class="label">Accent</span>
      <button class="tbtn" data-accent-btn="forest" type="button" aria-pressed="false">Forest</button>
      <button class="tbtn" data-accent-btn="coral" type="button" aria-pressed="false">Coral</button>
      <button class="tbtn" data-accent-btn="ocean" type="button" aria-pressed="false">Ocean</button>
      <button class="tbtn" data-accent-btn="ember" type="button" aria-pressed="false">Ember</button>
    </div>
  </div>
</div>

<header class="site-header">
  <a href="/" class="site-wordmark">Volod</a>

  <nav>
    <div class="nav-dd">
      <button
        class={"nav-dd-btn" + (Astro.url.pathname.startsWith("/about") ? " active" : "")}
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
      >
        About
        <span class="nav-dd-caret" aria-hidden="true"></span>
      </button>

      <div class="nav-dd-menu" role="menu" aria-label="About">
        <a href="/about/biography" role="menuitem">Biography</a>
        <a href="/about/resume" role="menuitem">Resume</a>
      </div>
    </div>

    <a href="/writing" class={Astro.url.pathname === "/writing" ? "active" : ""}>Writing</a>
    <a href="/testimonials" class={Astro.url.pathname === "/testimonials" ? "active" : ""}>Testimonials</a>
    <a href="/contact" class={Astro.url.pathname === "/contact" ? "active" : ""}>Contact</a>
  </nav>
</header>


    <slot />
  </div>

  <script>
    (function () {
      const root = document.documentElement;

      function setPressed(selector, value) {
        document.querySelectorAll(selector).forEach((btn) => {
          btn.setAttribute("aria-pressed", btn.getAttribute(btn.hasAttribute("data-mode-btn") ? "data-mode-btn" : "data-accent-btn") === value ? "true" : "false");
        });
      }

      function applyMode(mode) {
        if (mode === "system") {
          root.removeAttribute("data-mode");
        } else {
          root.setAttribute("data-mode", mode);
        }
        localStorage.setItem("mode", mode);
        setPressed("[data-mode-btn]", mode);
      }

      function applyAccent(accent) {
        root.setAttribute("data-accent", accent);
        localStorage.setItem("accent", accent);
        setPressed("[data-accent-btn]", accent);
      }

      // init
      const savedMode = localStorage.getItem("mode") || "system";
      const savedAccent = localStorage.getItem("accent") || "forest";
      applyMode(savedMode);
      applyAccent(savedAccent);

      // events
      document.querySelectorAll("[data-mode-btn]").forEach((btn) => {
        btn.addEventListener("click", () => applyMode(btn.getAttribute("data-mode-btn")));
      });

      document.querySelectorAll("[data-accent-btn]").forEach((btn) => {
        btn.addEventListener("click", () => applyAccent(btn.getAttribute("data-accent-btn")));
      });
    })();
  </script>

<script>
  (function () {
    const dd = document.querySelector(".nav-dd");
    if (!dd) return;

    const btn = dd.querySelector(".nav-dd-btn");
    const menu = dd.querySelector(".nav-dd-menu");

    function close() {
      btn.setAttribute("aria-expanded", "false");
      menu.style.display = "";
    }

    function toggle() {
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!isOpen));
      menu.style.display = isOpen ? "" : "block";
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });

    document.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  })();
</script>

</body>

</html>
